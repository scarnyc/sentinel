{
	"name": "@sentinel/agent",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc --build && tsup src/index.ts src/loop.ts --format esm",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"dev": "tsx src/loop.ts"
	},
	"dependencies": {
		"@sentinel/types": "workspace:*",
		"@anthropic-ai/sdk": "^0.39.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"tsup": "^8.4.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
