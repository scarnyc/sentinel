{
	"name": "sentinel",
	"private": true,
	"version": "0.1.0",
	"description": "Sentinel — Secure agent runtime with process isolation",
	"type": "module",
	"scripts": {
		"build": "pnpm -r run build",
		"typecheck": "tsc -b",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"format:check": "biome format ."
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@9.15.4",
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.3.3",
		"@vitest/coverage-v8": "^4.0.18",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
