{
	"name": "@sentinel/executor",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts src/server.ts src/entrypoint.ts --format esm --dts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"dev": "tsx src/server.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.14.0",
		"@sentinel/audit": "workspace:*",
		"@sentinel/crypto": "workspace:*",
		"@sentinel/policy": "workspace:*",
		"@sentinel/types": "workspace:*",
		"better-sqlite3": "^11.8.0",
		"execa": "^9.5.0",
		"hono": "^4.12.7",
		"undici": "^7.24.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@sentinel/openclaw-plugin": "workspace:*",
		"@types/better-sqlite3": "^7.6.12",
		"tsup": "^8.4.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
