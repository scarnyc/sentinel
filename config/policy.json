{
  "version": 1,
  "toolGroups": {
    "fs": ["read_file", "write_file", "edit_file"],
    "runtime": ["bash"],
    "network": ["browser", "fetch", "curl"],
    "messaging": ["slack", "discord", "telegram", "whatsapp"],
    "automation": ["sessions_spawn", "sessions_send", "gateway"]
  },
  "defaults": {
    "tools": {
      "allow": ["*"],
      "deny": ["group:network"]
    },
    "workspace": {
      "root": "~/.openclaw/workspace",
      "access": "rw"
    },
    "approval": {
      "ask": "on-miss"
    }
  },
  "agents": {}
}
